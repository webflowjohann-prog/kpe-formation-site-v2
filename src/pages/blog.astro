---
import BaseLayout from '../layouts/BaseLayout.astro';

const articles = [
  { slug: "kinesiologie-psycho-energetique-guide-complet", title: "Qu'est-ce que la kinésiologie psycho-énergétique ?", desc: "Le guide complet de la méthode KPE : origines, principes et bienfaits.", img: "/images/blog/seance-test-epaule.webp" },
  { slug: "devenir-kinesiologue-formation-salaire-debouches", title: "Devenir kinésiologue en 2026", desc: "Formation, salaire, débouchés — le guide de la reconversion.", img: "/images/blog/formation-groupe.webp" },
  { slug: "test-musculaire-kinesiologie-comment-ca-marche", title: "Le test musculaire : comment ça marche ?", desc: "Principe, déroulement et interprétation de l'outil fondamental.", img: "/images/blog/test-musculaire-bras.webp" },
  { slug: "14-meridiens-emotions-kinesiologie", title: "Les 14 méridiens et leurs émotions", desc: "La cartographie énergie-émotions de la médecine chinoise.", img: "/images/blog/correction-meridien.webp" },
  { slug: "formation-kinesiologie-en-ligne-vs-presentiel", title: "En ligne vs présentiel : comment choisir ?", desc: "Comparatif des deux formats de formation en kinésiologie.", img: "/images/blog/formation-groupe.webp" },
  { slug: "kinesiologie-stress-anxiete-liberation-emotionnelle", title: "Kinésiologie et stress : libérer les tensions", desc: "Techniques de libération émotionnelle pour retrouver la sérénité.", img: "/images/blog/correction-meridien.webp" },
  { slug: "reconversion-professionnelle-kinesiologie", title: "Reconversion : pourquoi la kinésiologie ?", desc: "Parcours, formation, installation — réussir votre changement de vie.", img: "/images/blog/joel-expert-fauteuil.webp" },
  { slug: "meridien-foie-colere-lien-corps-emotion", title: "Méridien du Foie et colère", desc: "Comment la frustration se cristallise dans le corps.", img: "/images/blog/points-meridien.webp" },
  { slug: "sinstaller-kinesiologue-guide-pratique", title: "S'installer kinésiologue : guide pratique", desc: "Statut, assurance, cabinet, clientèle — toutes les étapes.", img: "/images/blog/joel-bureau-livres.webp" },
  { slug: "kinesiologie-enfants-apprentissage-brain-gym", title: "Kinésiologie et enfants : Brain Gym", desc: "Aider les enfants en difficulté d'apprentissage.", img: "/images/blog/test-musculaire-lumiere.webp" },
];
---

<BaseLayout title="Blog KPE — Kinésiologie, Méridiens, Bien-être | Formation Kinésiologie" description="Articles sur la kinésiologie psycho-énergétique : méridiens, test musculaire, reconversion, développement personnel. Par Joël Prieur." breadcrumbs={[{name: "Blog", url: "/blog"}]}>

<section class="page-hero">
  <div class="container">
    <div class="page-hero-badge">Blog</div>
    <h1>Le Blog KPE</h1>
    <p class="page-hero-sub">Kinésiologie, méridiens, émotions, développement personnel — par Joël Prieur.</p>
  </div>
</section>

<section class="section">
  <div class="container">
    <div class="blog-grid">
      {articles.map((a) => (
        <a href={`/blog/${a.slug}`} class="blog-card">
          <div class="blog-card-img">
            <img src={a.img} alt={a.title} loading="lazy">
          </div>
          <div class="blog-card-body">
            <h2>{a.title}</h2>
            <p>{a.desc}</p>
            <span class="blog-card-link">Lire l'article →</span>
          </div>
        </a>
      ))}
    </div>
  </div>
</section>

<section class="section" style="background:var(--teal-900);text-align:center;color:white;">
  <div class="container">
    <img src="/images/logo-white.png" alt="KPE" width="48" height="48" style="margin:0 auto 20px;opacity:0.9;">
    <h2 style="font-family:var(--font-display);font-size:clamp(24px,3vw,40px);margin-bottom:16px;">Passez de la lecture à la pratique</h2>
    <p style="color:rgba(255,255,255,0.6);max-width:500px;margin:0 auto 30px;">Rejoignez les 6 000+ étudiants formés à la méthode KPE.</p>
    <a href="/formation-en-ligne" class="btn-primary" style="background:white;color:var(--teal-900);">Découvrir la formation →</a>
  </div>
</section>

</BaseLayout>

<style>
.page-hero { padding: clamp(120px,12vw,180px) 0 clamp(60px,6vw,100px); background: linear-gradient(135deg, var(--teal-50) 0%, var(--white) 100%); }
.page-hero h1 { font-family: var(--font-display); font-size: clamp(32px,4vw,56px); font-weight: 600; color: var(--gray-900); margin-bottom: 16px; line-height: 1.1; }
.page-hero-badge { display: inline-block; background: var(--teal-100); color: var(--teal-700); padding: 6px 16px; border-radius: 100px; font-size: 13px; font-weight: 600; margin-bottom: 20px; }
.page-hero-sub { font-size: clamp(15px,1.2vw,18px); color: var(--gray-500); max-width: 600px; line-height: 1.7; }
.blog-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(340px, 1fr)); gap: 24px; }
.blog-card { background: white; border: 1px solid var(--gray-100); border-radius: 16px; overflow: hidden; text-decoration: none; color: var(--gray-800); transition: all 0.3s; display: block; }
.blog-card:hover { border-color: var(--teal-400); transform: translateY(-4px); box-shadow: 0 12px 40px rgba(3,140,140,0.1); }
.blog-card-img { aspect-ratio: 16/9; overflow: hidden; }
.blog-card-img img { width: 100%; height: 100%; object-fit: cover; transition: transform 0.4s; }
.blog-card:hover .blog-card-img img { transform: scale(1.05); }
.blog-card-body { padding: 24px; }
.blog-card-body h2 { font-family: var(--font-display); font-size: 18px; font-weight: 600; color: var(--gray-900); margin-bottom: 8px; line-height: 1.3; }
.blog-card-body p { font-size: 14px; color: var(--gray-500); line-height: 1.5; margin-bottom: 16px; }
.blog-card-link { font-size: 14px; font-weight: 600; color: var(--teal-500); }
@media (max-width: 500px) { .blog-grid { grid-template-columns: 1fr; } }
</style>
