.back-link:hover { text-decoration: underline; }
.article-meta { display: flex; gap: 16px; margin-bottom: 16px; }
.article-date, .article-read { font-size: 13px; color: var(--gray-400); font-family: var(--font-mono); letter-spacing: 0.02em; }
