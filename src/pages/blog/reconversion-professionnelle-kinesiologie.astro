---
import BaseLayout from '../../layouts/BaseLayout.astro';
const articleSchema = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": "Reconversion professionnelle : pourquoi choisir la kinésiologie ?",
  "description": "Vous envisagez une reconversion en kinésiologie ? Parcours, formation, installation — tout pour réussir votre changement de vie.",
  "author": { "@type": "Person", "name": "Joël Prieur", "url": "https://www.formation-kinesiologie.com/joel-prieur" },
  "publisher": { "@type": "Organization", "name": "KPE", "logo": { "@type": "ImageObject", "url": "https://www.formation-kinesiologie.com/images/logo-teal.png" } },
  "datePublished": "2026-03-06",
  "dateModified": "2026-03-06",
  "mainEntityOfPage": "https://www.formation-kinesiologie.com/blog/reconversion-professionnelle-kinesiologie",
  "image": "https://www.formation-kinesiologie.com/images/blog/joel-expert-fauteuil.webp"
