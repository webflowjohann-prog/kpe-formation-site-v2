---
import BaseLayout from '../layouts/BaseLayout.astro';

const schema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    { "@type": "Question", "name": "La formation KPE est-elle éligible au CPF ?", "acceptedAnswer": { "@type": "Answer", "text": "La kinésiologie n'est pas encore inscrite au RNCP, donc la formation KPE n'est pas directement éligible au CPF. Cependant, des financements OPCO et France Travail sont possibles selon votre situation." }},
    { "@type": "Question", "name": "Puis-je payer la formation en plusieurs fois ?", "acceptedAnswer": { "@type": "Answer", "text": "Oui. La formation en ligne est payable en 3 fois sans frais (3 × 527€). La formation en présentiel se règle avec 999€ à l'inscription puis 3 × 1 000€." }},
    { "@type": "Question", "name": "Mon OPCO peut-il financer la formation ?", "acceptedAnswer": { "@type": "Answer", "text": "De nombreux OPCO financent les formations en bien-être et développement personnel. Contactez votre OPCO avec le programme détaillé de la formation KPE pour étudier votre éligibilité." }},
    { "@type": "Question", "name": "France Travail peut-il financer ma formation KPE ?", "acceptedAnswer": { "@type": "Answer", "text": "Si vous êtes demandeur d'emploi, France Travail (ex-Pôle Emploi) peut financer votre formation via l'AIF (Aide Individuelle à la Formation). Parlez-en à votre conseiller avec le programme KPE." }}
  ]
};
---

<BaseLayout title="Financer sa formation en kinésiologie | KPE — OPCO, France Travail, paiement en 3x" description="Comment financer votre formation en kinésiologie KPE ? OPCO, France Travail, paiement en 3 fois sans frais. Toutes les options de financement détaillées." schema={schema} breadcrumbs={[{name: "Financement", url: "/financement"}]}>

<section class="page-hero">
  <div class="container">
    <div class="page-hero-badge">Financement</div>
    <h1>Financer votre formation KPE</h1>
    <p class="page-hero-sub">Plusieurs solutions existent pour financer votre formation en kinésiologie. OPCO, France Travail, paiement en plusieurs fois — voici toutes vos options.</p>
  </div>
</section>

<section class="section">
  <div class="container">
    <div class="section-label">Les options</div>
    <h2 class="section-title">Trouvez le financement adapté à votre situation</h2>

    <div class="finance-grid">
      <div class="finance-card highlight">
        <div class="finance-icon">💳</div>
        <h3>Paiement en 3× sans frais</h3>
        <p class="finance-price">3 × 527 € <span>formation en ligne</span></p>
        <p>La solution la plus simple. Payez votre formation en 3 mensualités sans frais ni intérêts directement sur notre plateforme. Aucun dossier à constituer.</p>
        <a href="https://kpeonline.podia.com/formation-kpe-peurs-croyances" target="_blank" rel="noopener" class="btn-primary">S'inscrire en 3× →</a>
      </div>

      <div class="finance-card">
        <div class="finance-icon">🏢</div>
        <h3>Financement OPCO</h3>
        <p>Si vous êtes salarié, votre OPCO (Opérateur de Compétences) peut prendre en charge tout ou partie de votre formation. Les principaux OPCO qui financent les formations bien-être : AGEFICE, FIFPL, OPCO EP, FAFCEA.</p>
        <p><strong>Démarche :</strong> contactez votre OPCO avec le <a href="/formation-presentiel">programme détaillé de la formation KPE</a>, le devis et la convention de formation. Nous fournissons tous les documents nécessaires.</p>
      </div>

      <div class="finance-card">
        <div class="finance-icon">🇫🇷</div>
        <h3>France Travail (ex-Pôle Emploi)</h3>
        <p>Si vous êtes demandeur d'emploi, l'AIF (Aide Individuelle à la Formation) peut financer votre formation KPE. Cette aide couvre les frais pédagogiques.</p>
        <p><strong>Démarche :</strong> parlez-en à votre conseiller France Travail lors de votre prochain rendez-vous. Présentez le programme KPE comme un projet de <a href="/blog/reconversion-professionnelle-kinesiologie">reconversion professionnelle</a> avec un plan d'installation.</p>
      </div>

      <div class="finance-card">
        <div class="finance-icon">🏦</div>
        <h3>Autofinancement</h3>
        <p>La formation en ligne à 1 580€ est l'investissement le plus accessible du marché (les grandes écoles facturent 8 000 à 12 000€). Il suffit de 20-25 séances à tarif débutant pour rentabiliser intégralement la formation.</p>
        <p>Consultez notre <a href="/blog/sinstaller-kinesiologue-guide-pratique">guide d'installation</a> pour estimer votre retour sur investissement.</p>
      </div>
    </div>
  </div>
</section>

<section class="section" style="background:var(--gray-50);">
  <div class="container">
    <div class="section-label">Comparatif</div>
    <h2 class="section-title">Combien coûtent les formations en kinésiologie ?</h2>
    <div class="compare-table">
      <div class="compare-row header">
        <div>Formation</div><div>Prix</div><div>Durée</div><div>Format</div>
      </div>
      <div class="compare-row highlight">
        <div><strong>KPE en ligne</strong></div><div><strong>1 580 €</strong></div><div>À votre rythme</div><div>100% en ligne</div>
      </div>
      <div class="compare-row highlight">
        <div><strong>KPE présentiel</strong></div><div><strong>3 999 €</strong></div><div>8 week-ends</div><div>Aurillac</div>
      </div>
      <div class="compare-row">
        <div>EKTC</div><div>4 470 — 4 995 €</div><div>296h</div><div>Hybride</div>
      </div>
      <div class="compare-row">
        <div>Ekivie</div><div>8 770 €</div><div>600h</div><div>Présentiel</div>
      </div>
      <div class="compare-row">
        <div>Autres écoles</div><div>8 000 — 12 000 €</div><div>Variable</div><div>Présentiel</div>
      </div>
    </div>
    <p style="margin-top:20px;font-size:14px;color:var(--gray-400);text-align:center;">La KPE offre le meilleur rapport qualité-prix du marché avec un programme aussi complet que les formations à 10 000€+.</p>
  </div>
</section>

<section class="section" style="background:var(--teal-900);color:white;text-align:center;">
  <div class="container">
    <h2 style="font-family:var(--font-display);font-size:clamp(24px,3vw,40px);margin-bottom:16px;">Besoin d'aide pour votre dossier ?</h2>
    <p style="color:rgba(255,255,255,0.6);max-width:500px;margin:0 auto 30px;">Contactez-nous — nous vous aidons à constituer votre dossier de financement et fournissons tous les documents nécessaires.</p>
    <div style="display:flex;gap:16px;justify-content:center;flex-wrap:wrap;">
      <a href="/contact" class="btn-primary" style="background:white;color:var(--teal-900);">Nous contacter →</a>
      <a href="/formation-en-ligne" class="btn-primary" style="background:transparent;color:white;border:1.5px solid rgba(255,255,255,0.3);">Voir la formation →</a>
    </div>
  </div>
</section>

</BaseLayout>

<style>
.page-hero { padding: clamp(120px,12vw,180px) 0 clamp(60px,6vw,100px); background: linear-gradient(135deg, var(--teal-50) 0%, var(--white) 100%); }
.page-hero h1 { font-family: var(--font-display); font-size: clamp(32px,4vw,56px); font-weight: 600; color: var(--gray-900); margin-bottom: 16px; line-height: 1.1; }
.page-hero-badge { display: inline-block; background: var(--teal-100); color: var(--teal-700); padding: 6px 16px; border-radius: 100px; font-size: 13px; font-weight: 600; margin-bottom: 20px; }
.page-hero-sub { font-size: clamp(15px,1.2vw,18px); color: var(--gray-500); max-width: 600px; line-height: 1.7; }
.finance-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 20px; margin-top: 40px; }
.finance-card { background: var(--gray-50); border: 1px solid var(--gray-100); border-radius: 16px; padding: 32px; }
.finance-card.highlight { background: var(--teal-50); border-color: var(--teal-200); }
.finance-icon { font-size: 28px; margin-bottom: 12px; }
.finance-card h3 { font-family: var(--font-display); font-size: 20px; color: var(--gray-900); margin-bottom: 12px; }
.finance-card p { font-size: 14px; color: var(--gray-500); line-height: 1.6; margin-bottom: 12px; }
.finance-card a { color: var(--teal-500); }
.finance-price { font-family: var(--font-display); font-size: 24px; font-weight: 700; color: var(--teal-900); margin-bottom: 8px; }
.finance-price span { font-size: 13px; font-weight: 400; color: var(--gray-400); }
.compare-table { margin-top: 30px; border-radius: 16px; overflow: hidden; border: 1px solid var(--gray-100); }
.compare-row { display: grid; grid-template-columns: 1.5fr 1fr 1fr 1fr; padding: 16px 24px; font-size: 14px; color: var(--gray-600); border-bottom: 1px solid var(--gray-100); }
.compare-row:last-child { border-bottom: none; }
.compare-row.header { background: var(--gray-800); color: white; font-weight: 600; font-size: 13px; text-transform: uppercase; letter-spacing: 0.05em; }
.compare-row.highlight { background: var(--teal-50); }
.compare-row.highlight strong { color: var(--teal-900); }
@media (max-width: 600px) { .compare-row { grid-template-columns: 1fr 1fr; gap: 4px; font-size: 13px; } }
</style>
