---
import BaseLayout from '../layouts/BaseLayout.astro';

const schema = {
  "@context": "https://schema.org",
  "@type": "Course",
  "name": "Formation KPE en ligne",
  "description": "Formation complète en kinésiologie psycho-énergétique en ligne. 8 modules, 20h+ de vidéo, certificat de praticien. 1 580€ ou 3x 527€ sans frais.",
  "provider": { "@type": "Organization", "name": "KPE", "url": "https://www.formation-kinesiologie.com" },
  "offers": { "@type": "Offer", "price": "1580", "priceCurrency": "EUR", "availability": "https://schema.org/InStock", "url": "https://kpe-formation-site.netlify.app/achat" }
};
---

<BaseLayout title="Formation Kinésiologie en Ligne | KPE — 8 modules, 20h+ vidéo, 1 580€" description="Formez-vous à la kinésiologie psycho-énergétique en ligne avec Joël Prieur. 8 modules vidéo HD, supports PDF, assistance directe. Certificat de praticien. 1 580€ ou 3x 527€." breadcrumbs={[{name: "Formation en ligne", url: "/formation-en-ligne"}]} schema={schema}>

<section class="page-hero">
  <div class="container">
    <div class="page-hero-badge">Formation 100% en ligne</div>
    <h1>Formation KPE en ligne</h1>
    <p class="page-hero-sub">8 modules vidéo HD · 20h+ de formation · Supports PDF · Assistance directe avec Joël · Certificat de praticien KPE</p>
    <div class="page-hero-img"><img src="/images/blog/test-musculaire-bras.webp" alt="Séance de kinésiologie - test musculaire avec Joël Prieur"></div>
    <div class="page-hero-price">
      <span class="price-big">1 580 €</span>
      <span class="price-or">ou 3× 527 € sans frais</span>
    </div>
    <a href="/achat" class="btn-primary">
      S'inscrire maintenant →
    </a>
  </div>
</section>

<section class="section" style="background:var(--gray-50);">
  <div class="container">
    <div class="section-label">Ce qui est inclus</div>
    <h2 class="section-title">Tout ce dont vous avez besoin pour devenir praticien</h2>
    <div class="features-grid">
      <div class="feature-card">
        <div class="feature-icon">🎬</div>
        <h3>20h+ de vidéo HD</h3>
        <p>Chaque module est filmé avec des démonstrations pratiques claires. Vous voyez chaque geste, chaque test, chaque correction.</p>
      </div>
      <div class="feature-card">
        <div class="feature-icon">📄</div>
        <h3>Supports PDF complets</h3>
        <p>Les supports de chaque module sont téléchargeables et imprimables pour accompagner votre apprentissage.</p>
      </div>
      <div class="feature-card">
        <div class="feature-icon">📞</div>
        <h3>Assistance directe avec Joël</h3>
        <p>Contactez Joël Prieur directement par email ou téléphone. Vous n'êtes jamais seul dans votre apprentissage.</p>
      </div>
      <div class="feature-card">
        <div class="feature-icon">👥</div>
        <h3>Communauté Facebook & WhatsApp</h3>
        <p>Rejoignez le "cerveau collectif" : posez vos questions, échangez avec les autres étudiants, progressez ensemble.</p>
      </div>
      <div class="feature-card">
        <div class="feature-icon">⏰</div>
        <h3>À votre rythme, sans limite</h3>
        <p>Pas de date limite. Vous avancez selon vos disponibilités. La formation vous appartient pour toujours.</p>
      </div>
      <div class="feature-card">
        <div class="feature-icon">🎓</div>
        <h3>Certificat de praticien KPE</h3>
        <p>Après validation de votre étude de cas, vous recevez le certificat et pouvez vous installer en tant que praticien.</p>
      </div>
    </div>
  </div>
</section>

<section class="section">
  <div class="container">
    <div class="section-label">Programme détaillé</div>
    <h2 class="section-title">8 modules progressifs</h2>
    <div class="program-list">
      <div class="program-item"><strong>Module 1</strong> — Test musculaire, 14 muscles et méridiens, roue des méridiens, points d'alarme, métaphore des méridiens. Protocole Module 1. <em>80h d'intégration</em></div>
      <div class="program-item"><strong>Module 2</strong> — Modèle Universel de Santé, modes digitaux, 4 phases de test, procédure refoulement-accident, corrections émotionnelles, cadres de temps. Protocole Module 2 — reprend et enrichit le protocole du Module 1. <em>110h</em></div>
      <div class="program-item"><strong>Module 3</strong> — Références primaires, fonctionnement du cerveau, 9 intelligences, remodelage de latéralité, le corps point par point. Protocole Module 3 — reprend et enrichit les protocoles précédents. <em>70h</em></div>
      <div class="program-item"><strong>Module 4</strong> — Objectifs selon les méridiens, points NE/NV/NL, protocole selon les points de sabotage. Protocole Module 4 — reprend et enrichit les protocoles précédents. <em>50h</em></div>
      <div class="program-item"><strong>Module 5</strong> — Les chakras, les 7 corps subtils, les barrières, travail en transfert. Protocole Module 5 — reprend et enrichit les protocoles précédents. <em>60h</em></div>
      <div class="program-item"><strong>Module 6</strong> — Pouvoir personnel, sabotages, les 15 portes d'entrée, protocole de séance complet. Protocole Module 6 — reprend et enrichit les protocoles précédents. <em>60h</em></div>
      <div class="program-item"><strong>Module 7</strong> — Peurs, habitudes et croyances, neuro-transmetteurs, drainage lymphatique, traits inadaptés de la personnalité. Protocole Module 7 — reprend et enrichit les protocoles précédents. <em>70h</em></div>
      <div class="program-item"><strong>Module 8</strong> — Les 8 phases de test, 7 références génétiques, récepteurs de tête et de main, protocole de séance regroupant les protocoles des différents modules, création de clientèle. <em>100h</em></div>
    </div>

  </div>
</section>

<section class="section" style="background:var(--teal-900);color:white;text-align:center;">
  <div class="container">
    <img src="/images/logo-white.png" alt="KPE" width="64" height="64" style="margin:0 auto 20px;">
    <h2 style="font-family:var(--font-display);font-size:clamp(28px,3.5vw,44px);margin-bottom:16px;">Prêt à transformer votre parcours ?</h2>
    <p style="color:rgba(255,255,255,0.6);font-size:18px;max-width:500px;margin:0 auto 30px;">Rejoignez les 2 500+ étudiants qui ont choisi la méthode KPE.</p>
    <a href="/achat" class="btn-primary" style="background:white;color:var(--teal-900);">
      S'inscrire — 1 580 € →
    </a>
    <p style="color:rgba(255,255,255,0.4);font-size:13px;margin-top:12px;">ou 3× 527 € sans frais · Éligible financement OPCO / France Travail</p>
  </div>
</section>

</BaseLayout>

<style>
.page-hero { padding: clamp(120px,12vw,180px) 0 clamp(60px,6vw,100px); background: linear-gradient(135deg, var(--teal-50) 0%, var(--white) 100%); }
.page-hero h1 { font-family: var(--font-display); font-size: clamp(32px,4vw,56px); font-weight: 600; color: var(--gray-900); margin-bottom: 16px; line-height: 1.1; }
.page-hero-badge { display: inline-block; background: var(--teal-100); color: var(--teal-700); padding: 6px 16px; border-radius: 100px; font-size: 13px; font-weight: 600; margin-bottom: 20px; }
.page-hero-sub { font-size: clamp(15px,1.2vw,18px); color: var(--gray-500); max-width: 600px; line-height: 1.7; margin-bottom: 30px; }
.page-hero-price { margin-bottom: 30px; }
.page-hero-img { margin: 30px 0; border-radius: 16px; overflow: hidden; max-width: 600px; }
.page-hero-img img { width: 100%; height: auto; }
.price-big { font-family: var(--font-display); font-size: 36px; font-weight: 700; color: var(--teal-900); }
.price-or { font-size: 15px; color: var(--gray-400); margin-left: 8px; }
.features-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 20px; margin-top: 40px; }
.feature-card { background: white; border: 1px solid var(--gray-100); border-radius: 16px; padding: 28px; }
.feature-icon { font-size: 28px; margin-bottom: 12px; }
.feature-card h3 { font-family: var(--font-display); font-size: 18px; font-weight: 600; color: var(--gray-900); margin-bottom: 8px; }
.feature-card p { font-size: 14px; color: var(--gray-500); line-height: 1.6; }
.program-list { display: flex; flex-direction: column; gap: 12px; margin-top: 30px; }
.program-item { background: var(--gray-50); border: 1px solid var(--gray-100); border-radius: 12px; padding: 20px 24px; font-size: 15px; color: var(--gray-600); line-height: 1.6; }
.program-item strong { color: var(--teal-900); }
.program-item em { color: var(--teal-500); font-size: 13px; }
</style>
