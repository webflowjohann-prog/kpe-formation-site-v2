---
import BaseLayout from '../layouts/BaseLayout.astro';

const courseSchema = {
  "@context": "https://schema.org",
  "@type": "Course",
  "name": "Formation en Kinésiologie Psycho-Énergétique",
  "description": "Formation complète en kinésiologie psycho-énergétique par Joël Prieur. 8 modules, 20h+ de vidéo, accessible à tous. En ligne (1 580€) ou en présentiel à Aurillac (3 999€).",
  "provider": {
    "@type": "Organization",
    "name": "KPE - Kinésiologie Psycho-Énergétique",
    "url": "https://www.formation-kinesiologie.com"
  },
  "offers": [
    {
      "@type": "Offer",
      "name": "Formation en ligne",
      "price": "1580",
      "priceCurrency": "EUR",
      "availability": "https://schema.org/InStock",
      "url": "https://kpeonline.podia.com/formation-kpe-peurs-croyances"
    },
    {
      "@type": "Offer",
      "name": "Formation en présentiel",
      "price": "3999",
      "priceCurrency": "EUR",
      "availability": "https://schema.org/InStock"
    }
  ],
  "hasCourseInstance": {
    "@type": "CourseInstance",
    "courseMode": "blended",
    "location": {
      "@type": "Place",
      "name": "Hôtel Campanile Aurillac",
      "address": "ZAC de la Jordanne, 15000 Aurillac"
    },
    "startDate": "2026-09-19"
  },
  "aggregateRating": {
    "@type": "AggregateRating",
    "ratingValue": "4.8",
    "reviewCount": "2500",
    "bestRating": "5"
  }
};
---

<BaseLayout
  title="Formation Kinésiologie Psycho-Énergétique | KPE par Joël Prieur — En ligne & Présentiel"
  description="Devenez praticien en kinésiologie psycho-énergétique. Formation complète par Joël Prieur : 8 modules, 20h+ de vidéo, certificat. En ligne 1 580€ ou présentiel à Aurillac 3 999€. +2 500 étudiants formés."
  schema={courseSchema}
>

<!-- ═══ HERO ═══ -->
<section class="hero">
  <div class="hero-inner">
    <div class="hero-text">
      <div class="hero-badge">Rentrée Septembre 2026 — Aurillac</div>
      <h1>Devenez praticien en Kinésiologie <em>Psycho-Énergétique</em></h1>
      <p class="hero-sub">La méthode complète qui relie corps, énergie et psyché — pour transformer votre vie professionnelle et celle de vos futurs consultants. Accessible à tous, sans pré-requis.</p>
      <div class="hero-actions">
        <a href="#tarifs" class="btn-primary">
          Découvrir la formation
          <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </a>
        <a href="#programme" class="btn-secondary">
          <svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><polygon points="10 8 16 12 10 16 10 8" fill="currentColor" stroke="none"/></svg>
          Voir le programme
        </a>
      </div>
      <div class="hero-price">
        <span class="amount">1 580 €</span>
        <span class="note">· ou 3× 527 € sans frais</span>
      </div>
    </div>
    <div class="hero-visual">
      <div class="hero-card">
        <img class="hero-card-img" src="/images/joel-hero.webp" alt="Joël Prieur - Fondateur KPE">
        <div class="hero-card-overlay">
          <h3>Joël Prieur</h3>
          <p>Fondateur de la Méthode KPE</p>
        </div>
      </div>
      <div class="hero-float-card card-1">
        <div class="number">+2 500</div>
        <div class="label">Étudiants formés</div>
      </div>
      <div class="hero-float-card card-2">
        <div class="number">20h+</div>
        <div class="label">De vidéo de formation</div>
      </div>
    </div>
  </div>
</section>

<!-- ═══ SOCIAL PROOF BAR ═══ -->
<div class="proof-bar">
  <div class="proof-bar-inner">
    <div class="proof-item" style="display:flex;align-items:center;">
      <img src="/images/logo-teal.png" alt="KPE" style="height:48px;width:auto;">
    </div>
    <div class="proof-item">
      <div class="val">+2 500</div>
      <div class="lbl">Étudiants en ligne</div>
    </div>
    <div class="proof-item">
      <div class="val">+500</div>
      <div class="lbl">En présentiel</div>
    </div>
    <div class="proof-item">
      <div class="val">8</div>
      <div class="lbl">Modules complets</div>
    </div>
    <div class="proof-item">
      <div class="val">20h+</div>
      <div class="lbl">De vidéo HD</div>
    </div>
    <div class="proof-item">
      <div class="val">4.8/5</div>
      <div class="lbl">Satisfaction</div>
    </div>
  </div>
</div>

<!-- ═══ TRANSFORMATION ═══ -->
<section class="section transformation" id="methode">
  <div class="container">
    <div class="section-label">La Transformation</div>
    <h2 class="section-title">La KPE n'est pas une formation de plus. C'est un tournant.</h2>
    <p class="section-desc">Contrairement aux cursus généralistes, la méthode KPE est une synthèse unique de toutes les kinésiologies — conçue pour des résultats rapides et profonds.</p>
    
    <div class="transfo-grid">
      <div class="transfo-before">
        <div class="transfo-tag">Avant la KPE</div>
        <ul class="transfo-list">
          <li>Vous sentez que quelque chose bloque dans votre vie mais impossible d'identifier quoi</li>
          <li>Vous enchaînez les formations sans trouver d'outil vraiment complet</li>
          <li>Vous n'osez pas vous lancer dans une reconversion par peur de l'échec</li>
          <li>Vous êtes thérapeute mais il vous manque la dimension psycho-émotionnelle</li>
          <li>Vous ne savez pas comment passer de la théorie à la pratique en cabinet</li>
        </ul>
      </div>
      <div class="transfo-after">
        <div class="transfo-tag">Après la KPE</div>
        <ul class="transfo-list">
          <li>Vous identifiez avec précision l'origine de tout symptôme et mal-être</li>
          <li>Vous maîtrisez un outil "clés en main" reliant structure, énergie et psyché</li>
          <li>Vous êtes capable de mener une séance complète avec des résultats concrets</li>
          <li>Vous pouvez vous installer en tant que praticien certifié KPE</li>
          <li>Vous accompagnez vos consultants vers des changements profonds et durables</li>
        </ul>
      </div>
    </div>
  </div>
</section>

<!-- ═══ MODULES ═══ -->
<section class="section modules-section" id="programme">
  <div class="container">
    <div class="section-label">Le Programme</div>
    <h2 class="section-title">8 modules pour maîtriser la Kinésiologie Psycho-Énergétique</h2>
    <p class="section-desc">Un parcours progressif — de la découverte du test musculaire à la maîtrise complète des protocoles avancés.</p>
    
    <div class="modules-grid">
      <div class="module-card">
        <div class="module-num">01</div>
        <h3>Méridiens & Muscles</h3>
        <p>Les 14 méridiens de la médecine chinoise associés aux 14 muscles. Protocole de base et mise en situation avec un cas réel.</p>
        <span class="module-tag">80h d'intégration</span>
      </div>
      <div class="module-card">
        <div class="module-num">02</div>
        <h3>L'Appareil de Golgi</h3>
        <p>Test de précision avancé. Comprendre les subtilités du tonus musculaire pour des résultats d'une fiabilité remarquable.</p>
        <span class="module-tag">110h d'intégration</span>
      </div>
      <div class="module-card">
        <div class="module-num">03</div>
        <h3>Structure & Écologie</h3>
        <p>Les points neuro-lymphatiques, neuro-vasculaires et la relation structure-énergie-psyché.</p>
        <span class="module-tag">70h d'intégration</span>
      </div>
      <div class="module-card">
        <div class="module-num">04</div>
        <h3>Émotionnel & Psyché</h3>
        <p>Remonter aux chocs psycho-émotionnels conscients et inconscients. Le Baromètre du Comportement.</p>
        <span class="module-tag">50h d'intégration</span>
      </div>
      <div class="module-card">
        <div class="module-num">05</div>
        <h3>Corrections Profondes</h3>
        <p>Protocoles de sabotage, refoulement, inversion psychologique. Activer le changement sans effort.</p>
        <span class="module-tag">60h d'intégration</span>
      </div>
      <div class="module-card">
        <div class="module-num">06</div>
        <h3>Synthèse & Pratique</h3>
        <p>Maîtrise complète des 15 portes d'entrée de la KPE. Séances intégrales supervisées.</p>
        <span class="module-tag">60h d'intégration</span>
      </div>
      <div class="module-card">
        <div class="module-num">07</div>
        <h3>Peurs & Croyances</h3>
        <p>Module avancé : libération des peurs profondes, déconstruction des croyances limitantes et habitudes destructrices.</p>
        <span class="module-tag">Module avancé</span>
      </div>
      <div class="module-card">
        <div class="module-num">08</div>
        <h3>Les 8 Phases de Test</h3>
        <p>Le protocole ultime de la méthode KPE. Systématisation complète pour une pratique d'excellence.</p>
        <span class="module-tag">Module avancé</span>
      </div>
    </div>
  </div>
</section>

<!-- ═══ FORMATEUR ═══ -->
<section class="section formateur" id="formateur">
  <div class="container">
    <div style="margin-bottom:16px;"><img src="/images/logo-teal.png" alt="KPE" style="height:48px;width:auto;"></div>
    <div class="section-label">Le Formateur</div>
    <div class="formateur-grid">
      <div class="formateur-photo">
        <img style="width:100%;height:100%;object-fit:cover;" src="/images/joel-formateur.webp" alt="Joël Prieur">
      </div>
      <div class="formateur-content">
        <h3>Joël Prieur — la synthèse de <em>toutes les kinésiologies</em></h3>
        <p>Ancien professionnel de santé, Joël a consacré des années à comprendre pourquoi certaines douleurs ne correspondent pas aux signes radiologiques. De la kinésithérapie à l'ostéopathie, puis à la kinésiologie — il a construit la méthode KPE comme la synthèse de toutes ces approches.</p>
        <p>La KPE n'est pas un cours de plus. C'est le fruit d'une vie de recherche sur le lien entre le corps, l'énergie et la psyché. Avec plus de 2 500 étudiants formés dont plus de 150 en présentiel, Joël transmet un outil d'une précision rare.</p>
        <div class="formateur-credentials">
          <div class="credential"><div class="icon">⚕</div> Ancien professionnel de santé</div>
          <div class="credential"><div class="icon">🧠</div> Touch For Health, Brain Gym</div>
          <div class="credential"><div class="icon">⚡</div> Kinésiologie avancée & spécialisée</div>
          <div class="credential"><div class="icon">🤲</div> Ostéopathe D.O.</div>
          <div class="credential"><div class="icon">✦</div> Thérapie des corps subtils</div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ═══ TESTIMONIALS ═══ -->
<section class="section testimonials" id="temoignages">
  <div class="container">
    <div style="margin-bottom:24px;"><img src="/images/logo-teal.png" alt="KPE" style="height:64px;width:auto;"></div>
    <div class="section-label">Témoignages</div>
    <h2 class="section-title">Ils ont transformé leur vie grâce à la KPE</h2>
    <p class="section-desc">Des parcours divers, un même constat : la KPE change la donne.</p>
    
    <div class="testi-grid">
      <div class="testi-card">
        <div class="testi-stars">★★★★★</div>
        <blockquote>« J'ai pu m'installer rapidement, au bout de 5 mois. Joël saura vous transmettre avec une main de maître tous les secrets de la kinésiologie. »</blockquote>
        <div class="testi-author">
          <div class="testi-avatar">DC</div>
          <div><div class="testi-name">Delphine C.</div><div class="testi-role">Reconversion professionnelle</div></div>
        </div>
      </div>
      <div class="testi-card">
        <div class="testi-stars">★★★★★</div>
        <blockquote>« Le contenu de la formation était très enrichissant et très bien guidé. Cela demande rigueur et motivation, mais le résultat est là ! »</blockquote>
        <div class="testi-author">
          <div class="testi-avatar">MG</div>
          <div><div class="testi-name">Marion G.</div><div class="testi-role">Sophrologue en milieu hospitalier</div></div>
        </div>
      </div>
      <div class="testi-card">
        <div class="testi-stars">★★★★★</div>
        <blockquote>« Vos cours en ligne sont d'une grande qualité ! La KPE va encore plus loin que les autres formations. Je recommande chaudement. »</blockquote>
        <div class="testi-author">
          <div class="testi-avatar">KP</div>
          <div><div class="testi-name">Karen P.</div><div class="testi-role">Relaxologue</div></div>
        </div>
      </div>
      <div class="testi-card">
        <div class="testi-stars">★★★★★</div>
        <blockquote>« À la suite de la formation, je me suis installée en auto-entrepreneur. Je pratique 2 jours par semaine avec de très bons retours. »</blockquote>
        <div class="testi-author">
          <div class="testi-avatar">IG</div>
          <div><div class="testi-name">Isabelle G.</div><div class="testi-role">Praticienne KPE installée</div></div>
        </div>
      </div>
      <div class="testi-card">
        <div class="testi-stars">★★★★★</div>
        <blockquote>« Je n'en reviens pas d'être capable de conduire une séance de KPE moi-même ni de voir les résultats que j'obtiens sur mes patients. »</blockquote>
        <div class="testi-author">
          <div class="testi-avatar">PP</div>
          <div><div class="testi-name">Patricia P.</div><div class="testi-role">Ancienne consultante KPE</div></div>
        </div>
      </div>
      <div class="testi-card">
        <div class="testi-stars">★★★★★</div>
        <blockquote>« À recommander à tout thérapeute ou futur thérapeute. Super formation avec un super outil thérapeutique ! »</blockquote>
        <div class="testi-author">
          <div class="testi-avatar">CM</div>
          <div><div class="testi-name">Christophe M.</div><div class="testi-role">Thérapeute</div></div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ═══ PRICING ═══ -->
<section class="section pricing" id="tarifs">
  <div class="container">
    <div style="text-align:center;">
      <div style="margin-bottom:20px;"><img src="/images/logo-teal.png" alt="KPE" style="height:48px;width:auto;"></div>
      <div class="section-label">Tarifs</div>
      <h2 class="section-title">Investissez dans votre transformation</h2>
      <p class="section-desc" style="margin-left:auto;margin-right:auto;">La formation la plus complète du marché, à une fraction du prix des écoles généralistes.</p>
    </div>
    
    <div class="pricing-cards" style="margin-top:50px;">
      <div class="price-card main">
        <div class="popular-badge">Le + populaire</div>
        <div class="type">Formation en ligne</div>
        <h3>Formation Complète KPE</h3>
        <div class="price-amount">
          <span class="currency">€</span>
          <span class="value">1 580</span>
        </div>
        <p class="price-sub">ou 3 × 527 € sans frais</p>
        <ul class="price-features">
          <li>8 modules vidéo HD (+20 heures)</li>
          <li>Supports PDF téléchargeables par module</li>
          <li>Assistance téléphonique directe avec Joël</li>
          <li>Accès aux groupes Facebook & WhatsApp</li>
          <li>Apprenez à votre rythme, sans date limite</li>
          <li>Certificat de praticien KPE après validation</li>
          <li>Éligible financement OPCO / France Travail</li>
        </ul>
        <a href="https://kpeonline.podia.com/formation-kpe-peurs-croyances" class="btn-primary">
          S'inscrire maintenant
          <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </a>
      </div>
      <div class="price-card alt">
        <div class="type">Formation présentielle</div>
        <h3>8 Week-ends à Aurillac</h3>
        <div class="price-amount">
          <span class="currency" style="color:var(--teal-900);">€</span>
          <span class="value" style="color:var(--teal-900);">3 999</span>
        </div>
        <p class="price-sub">999 € à l'inscription + 3 × 1 000 €</p>
        <ul class="price-features">
          <li>Tout le contenu de la formation en ligne</li>
          <li>8 week-ends en présentiel (16 jours)</li>
          <li>2 formateurs pour un encadrement optimal</li>
          <li>Pratique intensive sur cas réels</li>
          <li>Entretiens téléphoniques réguliers</li>
          <li>Certificat de praticien KPE</li>
          <li>Éligible financement OPCO / France Travail</li>
        </ul>
        <a href="#inscription-presentiel" class="btn-primary">
          Voir les dates & s'inscrire
          <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </a>
      </div>
    </div>
    
    <div class="price-guarantee">
      <p>🛡 <strong>Éligible aux financements OPCO, France Travail et aides régionales.</strong> Nous vous accompagnons dans le montage de votre dossier de financement. La formation est assurée par un organisme certifié. Partenaire : <a href="https://www.studio-evolution.fr/formations/kpe/" style="color:var(--teal-500);text-decoration:underline;" target="_blank">Studio Évolution</a>.</p>
    </div>
  </div>
</section>

<!-- ═══ INSCRIPTION PRÉSENTIEL ═══ -->
<section class="section" id="inscription-presentiel" style="background:var(--white);">
  <div class="container">
    <div class="section-label">Formation présentielle</div>
    <h2 class="section-title">Inscription & calendrier — Aurillac 2026/2027</h2>
    <p class="section-desc">Pour vous inscrire à la formation en présentiel, téléchargez les documents ci-dessous, remplissez-les et renvoyez-les signés.</p>

    <!-- Documents à télécharger -->
    <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(260px,1fr));gap:16px;margin-top:40px;">
      <a href="https://cdn.prod.website-files.com/61962706bc4d205a7f34adcb/666f2e2cb73813b5ee6d5694_BULLETIN%20D%27INSCRIPTION.pdf" target="_blank" style="display:flex;align-items:center;gap:14px;background:var(--gray-50);border:1px solid var(--gray-200);border-radius:14px;padding:20px 24px;text-decoration:none;color:var(--gray-800);transition:all 0.25s;">
        <div style="width:44px;height:44px;background:var(--teal-50);border-radius:10px;display:flex;align-items:center;justify-content:center;flex-shrink:0;">
          <svg width="20" height="20" fill="none" stroke="#038C8C" stroke-width="2" viewBox="0 0 24 24"><path d="M12 3v12m0 0l-4-4m4 4l4-4M4 17v2a2 2 0 002 2h12a2 2 0 002-2v-2"/></svg>
        </div>
        <div>
          <div style="font-weight:600;font-size:14px;">Bulletin d'inscription</div>
          <div style="font-size:12px;color:var(--gray-400);margin-top:2px;">PDF — à remplir et renvoyer</div>
        </div>
      </a>
      <a href="https://cdn.prod.website-files.com/61962706bc4d205a7f34adcb/6253fae5cc9493507ec08aa0_engagement-financier.pdf" target="_blank" style="display:flex;align-items:center;gap:14px;background:var(--gray-50);border:1px solid var(--gray-200);border-radius:14px;padding:20px 24px;text-decoration:none;color:var(--gray-800);transition:all 0.25s;">
        <div style="width:44px;height:44px;background:var(--teal-50);border-radius:10px;display:flex;align-items:center;justify-content:center;flex-shrink:0;">
          <svg width="20" height="20" fill="none" stroke="#038C8C" stroke-width="2" viewBox="0 0 24 24"><path d="M12 3v12m0 0l-4-4m4 4l4-4M4 17v2a2 2 0 002 2h12a2 2 0 002-2v-2"/></svg>
        </div>
        <div>
          <div style="font-weight:600;font-size:14px;">Engagement financier</div>
          <div style="font-size:12px;color:var(--gray-400);margin-top:2px;">PDF — à remplir et renvoyer</div>
        </div>
      </a>
      <a href="https://cdn.prod.website-files.com/61962706bc4d205a7f34adcb/65f890756b0943b943042527_2024-03-CHARTE%20KPE.pdf" target="_blank" style="display:flex;align-items:center;gap:14px;background:var(--gray-50);border:1px solid var(--gray-200);border-radius:14px;padding:20px 24px;text-decoration:none;color:var(--gray-800);transition:all 0.25s;">
        <div style="width:44px;height:44px;background:var(--teal-50);border-radius:10px;display:flex;align-items:center;justify-content:center;flex-shrink:0;">
          <svg width="20" height="20" fill="none" stroke="#038C8C" stroke-width="2" viewBox="0 0 24 24"><path d="M12 3v12m0 0l-4-4m4 4l4-4M4 17v2a2 2 0 002 2h12a2 2 0 002-2v-2"/></svg>
        </div>
        <div>
          <div style="font-weight:600;font-size:14px;">Charte KPE</div>
          <div style="font-size:12px;color:var(--gray-400);margin-top:2px;">PDF — à signer</div>
        </div>
      </a>
      <a href="https://cdn.prod.website-files.com/61962706bc4d205a7f34adcb/694877310861c14fef48dd18_contrat%20de%20formation%20-%20KPE.pdf" target="_blank" style="display:flex;align-items:center;gap:14px;background:var(--gray-50);border:1px solid var(--gray-200);border-radius:14px;padding:20px 24px;text-decoration:none;color:var(--gray-800);transition:all 0.25s;">
        <div style="width:44px;height:44px;background:var(--teal-50);border-radius:10px;display:flex;align-items:center;justify-content:center;flex-shrink:0;">
          <svg width="20" height="20" fill="none" stroke="#038C8C" stroke-width="2" viewBox="0 0 24 24"><path d="M12 3v12m0 0l-4-4m4 4l4-4M4 17v2a2 2 0 002 2h12a2 2 0 002-2v-2"/></svg>
        </div>
        <div>
          <div style="font-weight:600;font-size:14px;">Contrat de formation</div>
          <div style="font-size:12px;color:var(--gray-400);margin-top:2px;">PDF — à signer</div>
        </div>
      </a>
    </div>

