---
import BaseLayout from '../layouts/BaseLayout.astro';

const schema = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  "name": "Témoignages des étudiants KPE",
  "description": "Avis et témoignages des étudiants formés à la méthode KPE par Joël Prieur.",
  "numberOfItems": 7
};

const temoignages = [
  { name: "Marie D.", role: "Reconversion après 15 ans en comptabilité", stars: 5, text: "La KPE a changé ma vie. En 6 mois j'ai quitté mon poste en comptabilité et ouvert mon cabinet. Les résultats avec mes consultants sont impressionnants dès les premières séances.", initials: "MD" },
  { name: "Thomas R.", role: "Ostéopathe D.O.", stars: 5, text: "J'intègre la KPE dans chaque consultation d'ostéopathie. Le test musculaire de précision m'a ouvert des portes que je ne soupçonnais pas. La dimension psycho-émotionnelle complète parfaitement mon approche.", initials: "TR" },
  { name: "Sophie L.", role: "Coach en développement personnel", stars: 5, text: "Après plusieurs formations en PNL et coaching, la KPE m'a apporté l'outil qui me manquait : le test musculaire. Mes clients ressentent la différence immédiatement.", initials: "SL" },
  { name: "Laurent P.", role: "Kinésiologue installé depuis 2 ans", stars: 5, text: "Le rapport qualité-prix est imbattable. J'ai comparé avec l'EKTC et Ekivie — la KPE offre un programme aussi complet pour une fraction du prix. Et l'accès direct à Joël est un vrai plus.", initials: "LP" },
  { name: "Isabelle M.", role: "Infirmière en reconversion", stars: 5, text: "Mon background médical m'a permis d'intégrer rapidement les concepts. Mais ce qui m'a surprise, c'est la puissance de l'approche émotionnelle. La KPE va bien au-delà de ce que j'imaginais.", initials: "IM" },
  { name: "Pierre C.", role: "Praticien bien-être", stars: 5, text: "Le module sur les sabotages inconscients a tout changé dans ma pratique. Je comprends enfin pourquoi certains clients restaient bloqués malgré les séances. La KPE désamorce les causes profondes.", initials: "PC" },
];
---

<BaseLayout title="Témoignages | KPE — Ce que disent nos étudiants" description="Découvrez les témoignages des étudiants formés à la kinésiologie psycho-énergétique par Joël Prieur. Reconversions réussies, praticiens installés, résultats concrets." schema={schema} breadcrumbs={[{name: "Témoignages", url: "/temoignages"}]}>

<section class="page-hero">
  <div class="container">
    <div class="page-hero-badge">Témoignages</div>
    <h1>Ils ont choisi la KPE</h1>
    <p class="page-hero-sub">Reconversions réussies, praticiens installés, résultats concrets — les étudiants de Joël Prieur partagent leur expérience.</p>
  </div>
</section>

<section class="section">
  <div class="container">
    <div class="section-label">Témoignages vidéo</div>
    <h2 class="section-title">Ils témoignent en vidéo</h2>
