---
import BaseLayout from '../layouts/BaseLayout.astro';

const schema = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  "name": "Témoignages des étudiants KPE",
  "description": "Avis et témoignages des étudiants formés à la méthode KPE par Joël Prieur.",
  "numberOfItems": 6
};

const temoignages = [
  { name: "Marie D.", role: "Reconversion après 15 ans en comptabilité", stars: 5, text: "La KPE a changé ma vie. En 6 mois j'ai quitté mon poste en comptabilité et ouvert mon cabinet. Les résultats avec mes consultants sont impressionnants dès les premières séances.", initials: "MD" },
  { name: "Thomas R.", role: "Ostéopathe D.O.", stars: 5, text: "J'intègre la KPE dans chaque consultation d'ostéopathie. Le test musculaire de précision m'a ouvert des portes que je ne soupçonnais pas. La dimension psycho-émotionnelle complète parfaitement mon approche.", initials: "TR" },
  { name: "Sophie L.", role: "Coach en développement personnel", stars: 5, text: "Après plusieurs formations en PNL et coaching, la KPE m'a apporté l'outil qui me manquait : le test musculaire. Mes clients ressentent la différence immédiatement.", initials: "SL" },
  { name: "Laurent P.", role: "Kinésiologue installé depuis 2 ans", stars: 5, text: "Le rapport qualité-prix est imbattable. J'ai comparé avec l'EKTC et Ekivie — la KPE offre un programme aussi complet pour une fraction du prix. Et l'accès direct à Joël est un vrai plus.", initials: "LP" },
  { name: "Isabelle M.", role: "Infirmière en reconversion", stars: 5, text: "Mon background médical m'a permis d'intégrer rapidement les concepts. Mais ce qui m'a surprise, c'est la puissance de l'approche émotionnelle. La KPE va bien au-delà de ce que j'imaginais.", initials: "IM" },
  { name: "Pierre C.", role: "Praticien bien-être", stars: 5, text: "Le module sur les sabotages inconscients a tout changé dans ma pratique. Je comprends enfin pourquoi certains clients restaient bloqués malgré les séances. La KPE désamorce les causes profondes.", initials: "PC" },
];
---

<BaseLayout title="Témoignages | KPE — Ce que disent nos étudiants" description="Découvrez les témoignages des étudiants formés à la kinésiologie psycho-énergétique par Joël Prieur. Reconversions réussies, praticiens installés, résultats concrets." schema={schema} breadcrumbs={[{name: "Témoignages", url: "/temoignages"}]}>

<section class="page-hero">
  <div class="container">
    <div class="page-hero-badge">Témoignages</div>
    <h1>Ils ont choisi la KPE</h1>
    <p class="page-hero-sub">Reconversions réussies, praticiens installés, résultats concrets — les étudiants de Joël Prieur partagent leur expérience.</p>
  </div>
</section>

<section class="section">
  <div class="container">
    <div class="section-label">Témoignages vidéo</div>
    <h2 class="section-title">Ils témoignent en vidéo</h2>
    <div class="video-placeholder">
      <img src="/images/blog/joel-expert-fauteuil.webp" alt="Témoignages vidéo KPE" style="width:100%;border-radius:16px;opacity:0.3;">
      <div class="video-overlay">
        <p>Les témoignages vidéo arrivent bientôt.</p>
        <p style="font-size:13px;color:var(--gray-400);">Nous préparons les vidéos de nos étudiants — elles seront ajoutées ici prochainement.</p>
      </div>
    </div>
  </div>
</section>

<section class="section" style="background:var(--gray-50);">
  <div class="container">
    <div class="section-label">Avis écrits</div>
    <h2 class="section-title">Ce qu'ils en disent</h2>
    <div class="testi-grid">
      {temoignages.map(t => (
        <div class="testi-card">
          <div class="testi-stars">{"★".repeat(t.stars)}</div>
          <blockquote>"{t.text}"</blockquote>
          <div class="testi-author">
            <div class="testi-avatar">{t.initials}</div>
            <div>
              <div class="testi-name">{t.name}</div>
              <div class="testi-role">{t.role}</div>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<section class="section" style="background:var(--teal-900);color:white;text-align:center;">
  <div class="container">
    <h2 style="font-family:var(--font-display);font-size:clamp(24px,3vw,40px);margin-bottom:16px;">Rejoignez-les</h2>
    <p style="color:rgba(255,255,255,0.6);max-width:500px;margin:0 auto 30px;">Plus de 6 000 étudiants ont choisi la méthode KPE. Et vous ?</p>
    <div style="display:flex;gap:16px;justify-content:center;flex-wrap:wrap;">
      <a href="/formation-en-ligne" class="btn-primary" style="background:white;color:var(--teal-900);">Formation en ligne — 1 580€ →</a>
      <a href="/formation-presentiel" class="btn-primary" style="background:transparent;color:white;border:1.5px solid rgba(255,255,255,0.3);">Présentiel — 3 999€ →</a>
    </div>
  </div>
</section>

</BaseLayout>

<style>
.page-hero { padding: clamp(120px,12vw,180px) 0 clamp(60px,6vw,100px); background: linear-gradient(135deg, var(--teal-50) 0%, var(--white) 100%); }
.page-hero h1 { font-family: var(--font-display); font-size: clamp(32px,4vw,56px); font-weight: 600; color: var(--gray-900); margin-bottom: 16px; line-height: 1.1; }
.page-hero-badge { display: inline-block; background: var(--teal-100); color: var(--teal-700); padding: 6px 16px; border-radius: 100px; font-size: 13px; font-weight: 600; margin-bottom: 20px; }
.page-hero-sub { font-size: clamp(15px,1.2vw,18px); color: var(--gray-500); max-width: 600px; line-height: 1.7; }
.video-placeholder { position: relative; border-radius: 16px; overflow: hidden; margin-top: 30px; }
.video-overlay { position: absolute; top: 50%; left: 50%; transform: translate(-50%,-50%); text-align: center; }
.video-overlay p { color: var(--gray-600); font-size: 16px; font-weight: 500; }
.testi-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(320px, 1fr)); gap: 20px; margin-top: 40px; }
.testi-card { background: white; border: 1px solid var(--gray-100); border-radius: 16px; padding: 28px; }
.testi-stars { color: var(--gold); font-size: 16px; letter-spacing: 2px; margin-bottom: 12px; }
.testi-card blockquote { font-size: 15px; color: var(--gray-600); line-height: 1.7; font-style: italic; margin-bottom: 20px; }
.testi-author { display: flex; align-items: center; gap: 12px; }
.testi-avatar { width: 40px; height: 40px; border-radius: 50%; background: var(--teal-500); display: flex; align-items: center; justify-content: center; font-weight: 600; font-size: 14px; color: white; flex-shrink: 0; }
.testi-name { font-weight: 600; font-size: 14px; color: var(--gray-800); }
.testi-role { font-size: 12px; color: var(--gray-400); }
</style>
