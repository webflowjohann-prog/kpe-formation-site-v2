</section>

<!-- Video lightbox modal -->
<div id="video-modal" class="video-modal" onclick="closeVideoModal(event)">
  <button class="video-modal-close" onclick="closeVideoModal(event)" aria-label="Fermer">&times;</button>
  <div class="video-modal-content" onclick="event.stopPropagation()">
    <iframe id="video-modal-iframe" src="" allow="autoplay; fullscreen" allowfullscreen style="width:100%;height:100%;border:none;border-radius:12px;"></iframe>
  </div>
</div>

<section class="section" style="background:var(--gray-50);">
  <div class="container">
    <div class="section-label">Avis écrits</div>
    <h2 class="section-title">Ce qu'ils en disent</h2>
    <div class="testi-grid">
      {temoignages.map(t => (
        <div class="testi-card">
          <div class="testi-stars">{"★".repeat(t.stars)}</div>
          <blockquote>"{t.text}"</blockquote>
          <div class="testi-author">
            <div class="testi-avatar">{t.initials}</div>
            <div>
              <div class="testi-name">{t.name}</div>
              <div class="testi-role">{t.role}</div>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

